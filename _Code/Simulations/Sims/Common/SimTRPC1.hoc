endtemplate SimTRPC1


// ==============================================================================
// TRPC1Iteration — updates tnfa_TRPC1 every timestep (section midpoint)
// ==============================================================================
proc TRPC1Iteration() { local tau1, tau2, BaselineTNFa, \
                             dist_sq1, dist_sq2, z_diff, tnfa_profile, \
                             xc, yc, zc
    tau1         = $5
    tau2         = $8
    BaselineTNFa = 0.1

    forall {
        if (ismembrane("TRPC1")) {
            xc=0  yc=0  zc=0
            if (n3d() > 0) {
                xc = (x3d(0) + x3d(n3d()-1)) / 2
                yc = (y3d(0) + y3d(n3d()-1)) / 2
                zc = (z3d(0) + z3d(n3d()-1)) / 2
            }
            dist_sq1 = dist2D_PtToPt_squared_trpc1($1,    $2, xc, yc)
            dist_sq2 = dist2D_PtToPt_squared_trpc1($1+$7, $2, xc, yc)
            z_diff   = abs($9 - zc)

            if (((dist_sq1<$3*$3)||(dist_sq2<$3*$3)) && (z_diff<15) && (t>$4)) {
                if (tau2 != tau1) {
                    tnfa_profile = BaselineTNFa \
                        + $6*(tau2/(tau2-tau1))*(exp(-(t-$4)/tau2)-exp(-(t-$4)/tau1))
                } else {
                    tnfa_profile = BaselineTNFa + $6*((t-$4)/tau1)*exp(1-(t-$4)/tau1)
                }
                if (tnfa_profile < 0) { tnfa_profile = BaselineTNFa }
                if (dist_sq1 < $3*$3) {
                    tnfa_profile = tnfa_profile*(1 - sqrt(dist_sq1)/($3*1.5))
                }
                tnfa_TRPC1 = tnfa_profile
            } else {
                tnfa_TRPC1 = BaselineTNFa
            }
        }
    }
}
