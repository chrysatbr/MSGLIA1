proc _SectionInsertTRPV4Mechanisms() {
    insert TRPV4
    
    // === TRPV4 EXPRESSION PARAMETERS ===
    trpv4_baseline_TRPV4 = 1.0
    tau_expression_TRPV4 = 86400000        // 24h in ms (slow time scale)
    tnfa_sensitivity_TRPV4 = 0.5
    tnfa_threshold_trpv4_TRPV4 = 1.0
    max_expression_fold_TRPV4 = 3.0
    
    // === CHANNEL ACTIVATION PARAMETERS ===
    // Agonist (GSK1016790A)
    agonist_conc_TRPV4 = 0
    agonist_ec50_TRPV4 = 5.0               // nM
    agonist_hill_TRPV4 = 2.0
    
    // Antagonist (GSK2193874)
    antagonist_conc_TRPV4 = 0
    antagonist_ic50_TRPV4 = 40.0           // nM
    antagonist_hill_TRPV4 = 1.5
    
    // Inflammatory activation
    tnfa_conc_ext_TRPV4 = 0                // External TNFα concentration
    inflammatory_sensitivity_TRPV4 = 0.3
    
    // Mechanical/shear stress activation
    shear_stress_TRPV4 = 0                 // dyn/cm2
    shear_sensitivity_TRPV4 = 0.02
    shear_threshold_TRPV4 = 5.0
    
    // ATP autocrine signaling
    atp_production_rate_TRPV4 = 0.01
    atp_decay_rate_TRPV4 = 0.05
    atp_sensitivity_TRPV4 = 0.4
    
    // Calcium sensitization
    ca_sensitivity_trpv4_TRPV4 = 1.5
    ca_threshold_trpv4_TRPV4 = 0.0001      // mM
    
    // Activation kinetics
    tau_activation_TRPV4 = 100             // ms (fast)
    tau_deactivation_TRPV4 = 500           // ms
    
    // === CHANNEL CONDUCTANCE PARAMETERS ===
    g_trpv4_max_TRPV4 = 0.0005             // S/cm2
    
    // Ion permeabilities (Ca2+ > Na+ > K+)
    pca_trpv4_TRPV4 = 10.0                 // High calcium permeability
    pna_trpv4_TRPV4 = 1.0
    pk_trpv4_TRPV4 = 0.8
    
    // === NFκB SIGNALING PARAMETERS ===
    nfkb_activation_rate_TRPV4 = 0.08
    nfkb_decay_rate_TRPV4 = 0.015
    nfkb_threshold_TRPV4 = 0.05
    tau_nfkb_TRPV4 = 3600000               // 1h in ms
    
    // === TIGHT JUNCTION PROTEIN PARAMETERS ===
    // Claudin-5 regulation
    cldn5_baseline_TRPV4 = 1.0
    cldn5_trpv4_dependence_TRPV4 = 0.6     // Structural support role
    cldn5_inflammatory_loss_TRPV4 = 0.3    // Degradation during inflammation
    tau_junction_proteins_TRPV4 = 7200000   // 2h in ms
    
    // VE-Cadherin regulation
    vecad_baseline_TRPV4 = 1.0
    vecad_trpv4_dependence_TRPV4 = 0.4
    vecad_inflammatory_loss_TRPV4 = 0.2
    
    // === CELL ADHESION MOLECULE PARAMETERS ===
    tau_adhesion_molecules_TRPV4 = 14400000 // 4h in ms
    
    // ICAM1 (intercellular adhesion molecule-1)
    icam1_baseline_TRPV4 = 0.3
    icam1_inflammatory_gain_TRPV4 = 5.0
    icam1_trpv4_modulation_TRPV4 = 0.4
    
    // VCAM1 (vascular cell adhesion molecule-1)
    vcam1_baseline_TRPV4 = 0.2
    vcam1_inflammatory_gain_TRPV4 = 8.0
    vcam1_trpv4_modulation_TRPV4 = 0.5
    
    // E-selectin (SELE)
    sele_baseline_TRPV4 = 0.1
    sele_inflammatory_gain_TRPV4 = 15.0    // Most sensitive to TRPV4
    sele_trpv4_modulation_TRPV4 = 0.6
    
    // === CYTOKINE/CHEMOKINE PARAMETERS ===
    // CCL2 (MCP-1) - NFκB-dependent
    ccl2_baseline_TRPV4 = 0.1
    ccl2_nfkb_dependence_TRPV4 = 2.0
    ccl2_decay_rate_TRPV4 = 0.0001
    
    // CCL5 (RANTES) - inflammatory induction
    ccl5_baseline_TRPV4 = 0.05
    ccl5_inflammatory_gain_TRPV4 = 3.0
    ccl5_decay_rate_TRPV4 = 0.0001
    
    // Caveolin-1 (barrier dysfunction marker)
    cav1_baseline_TRPV4 = 0.5
    cav1_inflammatory_gain_TRPV4 = 10.0
    cav1_trpv4_dependence_TRPV4 = 0.3
}

proc _SectionInsertTRPA1Mechanisms() {
    insert trpa1
    
    // === CHANNEL BIOPHYSICS ===
    single_channel_cond_trpa1 = 120
    g_trpa1 = 0.00015
    pca_trpa1 = 6.5
    pna_trpa1 = 1.0
    pk_trpa1 = 0.9
    
    // === ACTIVATION KINETICS ===
    tau_activation_trpa1 = 0.5
    tau_deactivation_trpa1 = 5
    
    // === CALCIUM MODULATION ===
    ca_ec50_pot_trpa1 = 0.0009
    ca_ec50_inact_trpa1 = 0.005
    tau_potentiation_trpa1 = 0.3
    tau_inactivation_trpa1 = 10
    tau_recovery_trpa1 = 60
    
    // === AGONIST/ANTAGONIST ===
    agonist_conc_trpa1 = 0
    agonist_ec50_trpa1 = 65.0
    agonist_hill_trpa1 = 1.8
    antagonist_conc_trpa1 = 0
    antagonist_ic50_trpa1 = 6.0
    antagonist_hill_trpa1 = 1.5
    
    // === OXIDATIVE STRESS ===
    oxidative_stress_trpa1 = 0
    ros_conc_trpa1 = 0
    h2o2_conc_trpa1 = 0
    hne_conc_trpa1 = 0
    lps_conc_trpa1 = 0
    oxidative_sens_trpa1 = 2.0
    ros_threshold_trpa1 = 0.1
    
    // === EXPRESSION ===
    trpa1_baseline = 1.0
    expression_ros_sens_trpa1 = 0.5
    tau_expression_trpa1 = 720
    
    // === NF-kB PATHWAY ===
    nfkb_act_rate_trpa1 = 0.1
    nfkb_decay_trpa1 = 0.02
    nfkb_threshold_trpa1 = 0.05
    tau_nfkb_trpa1 = 45
    
    // === CYTOKINES ===
    tnfa_baseline_trpa1 = 0.1
    il1b_baseline_trpa1 = 0.1
    il6_baseline_trpa1 = 0.1
    ccl2_baseline_trpa1 = 0.1
    cytokine_nfkb_dep_trpa1 = 2.0
    cytokine_decay_trpa1 = 0.01
    
    // === GEOMETRY ===
    density_scale_mode_trpa1 = 1
    density_scale_factor_trpa1 = 1.0
    
    // === CONSTITUTIVE/BASAL ===
    basal_open_prob_trpa1 = 0.05
    max_open_prob_trpa1 = 0.8
    
    // === LEGACY ===
    tau_desens_trpa1 = 2000
    tau_rise_spotty_trpa1 = 100
    tau_decay_spotty_trpa1 = 500
    spotty_frequency_trpa1 = 0.49
    spotty_amplitude_max_trpa1 = 2.0
    spotty_ca_scale_trpa1 = 0.0001
    agonist_sensitivity_trpa1 = 2.0
    blocker_sensitivity_trpa1 = 5.0
    oxidative_sensitivity_trpa1 = 1.5
    temp_sensitivity_trpa1 = 0.03
    temp_coefficient_trpa1 = 2.5
    ca_modulation_strength_trpa1 = 0.0
}

