// ================================================================
// FUS (Focused Ultrasound) Mechanism Insertion
// ================================================================
// APPEND THIS CODE AT THE END OF MechanismSwitch_deprecated.hoc
// (after the InsertTRPA1Mechanisms procedure)
//
// To add a new mechanoreceptor type:
//   1. Add its _SectionInsert*() call inside _SectionInsertFUSMechanisms()
//   2. Add its force coupling in the FUS iteration proc (SimFUS*.hoc)
// ================================================================

proc _SectionInsertFUSFieldMechanism() {
    insert FUS_field
    // Default transducer parameters (overridden from UI)
    freq_FUS_field = 500
    pressure_source_FUS_field = 0.5
    focal_length_FUS_field = 50
    aperture_diam_FUS_field = 25
    attenuation_FUS_field = 0.3
    sound_speed_FUS_field = 1540
    tissue_density_FUS_field = 1040
    x_focus_FUS_field = 0
    y_focus_FUS_field = 0
    z_focus_FUS_field = 0
}

proc _SectionInsertFUSMechanisms() {
    // Acoustic field model
    _SectionInsertFUSFieldMechanism()

    // Calcium dynamics (required for FUS calcium coupling)
    _SectionInsertCadifus()

    // All mechanosensitive channels
    _SectionInsertPiezo1Mechanisms()
    _SectionInsertPiezo2Mechanisms()
    _SectionInsertTRPV4Mechanisms()
    _SectionInsertTRPA1Mechanisms()
    _SectionInsertTRPC1Mechanisms()
}

proc InsertFUSMechanisms() {

    // Soma, Dendrites, Leaves / heads, Stalks / necks
    for eachSecInList(soma_ref, dendrite_ref, nanoDistal_ref, nanoProximal_ref) {
        _SectionInsertFUSMechanisms()
    }
}

// Insert mechanisms for Glutamate simulation.
proc InsertGlutamateMechanisms() {

    // Soma, Dendrites, Stalks / necks
    for eachSecInList(soma_ref, dendrite_ref, nanoProximal_ref) {
        _SectionInsertGlutamateMechanisms()
    }
    
    // Leaves / heads
    for eachSecInList(nanoDistal_ref) {
        _SectionInsertGlutamateMechanisms()
        density_GluTrans=(1+diam/(2*L))*DensityGluTransporters
    }
    
    // Stalks / necks
    /* !! moved here from AstrocyteNanoBranch.updateBiophysics
    for eachSecInList(nanoProximal_ref) {
        density_GluTrans = DensityGluTransporters
    }
    */
    
    // !! how about axon_ref, endFoot_ref and other_ref?
}


