// "Soma"
proc _addHomogenVarsInfoToBiophysComp1() { local idx localobj comp, mechIdxs, mechStd
    comp = $o1
    
    mechIdxs = new Vector(6)
    mechIdxs.x[0] = mth.getMechIdx(0, "morphology")
    mechIdxs.x[1] = mth.getMechIdx(0, "capacitance")
    mechIdxs.x[2] = mth.getMechIdx(0, "pas")
    mechIdxs.x[3] = mth.getMechIdx(0, "na_ion")
    mechIdxs.x[4] = mth.getMechIdx(0, "k_ion")
    mechIdxs.x[5] = mth.getMechIdx(0, "hh")
    
    for idx = 0, 5 {
        comp.isMechInserted[mechIdxs.x[idx]] = 1
    }
    
    mechStd = new MechanismStandard("morphology", 1)    // PARAMETER
    mechStd.set("diam", 20.0)    // (um)
    comp.mechStds[mechIdxs.x[0]][0] = mechStd
    
    mechStd = new MechanismStandard("capacitance", 1)    // PARAMETER
    mechStd.set("cm", 0.8)    // (uF/cm2)
    comp.mechStds[mechIdxs.x[1]][0] = mechStd
    
    mechStd = new MechanismStandard("pas", 1)    // PARAMETER
    mechStd.set("g_pas", 8.968609865470852e-05)    // (S/cm2)
    mechStd.set("e_pas", -85.0)    // (mV)
    comp.mechStds[mechIdxs.x[2]][0] = mechStd
}

// "Dendrites"
proc _addHomogenVarsInfoToBiophysComp2() { local idx localobj comp, mechIdxs, mechStd
    comp = $o1
    
    mechIdxs = new Vector(3)
    mechIdxs.x[0] = mth.getMechIdx(0, "morphology")
    mechIdxs.x[1] = mth.getMechIdx(0, "capacitance")
    mechIdxs.x[2] = mth.getMechIdx(0, "pas")
    
    for idx = 0, 2 {
        comp.isMechInserted[mechIdxs.x[idx]] = 1
    }
    
    mechStd = new MechanismStandard("morphology", 1)    // PARAMETER
    mechStd.set("diam", 1.0)    // (um)
    comp.mechStds[mechIdxs.x[0]][0] = mechStd
    
    mechStd = new MechanismStandard("capacitance", 1)    // PARAMETER
    mechStd.set("cm", 0.8)    // (uF/cm2)
    comp.mechStds[mechIdxs.x[1]][0] = mechStd
    
    mechStd = new MechanismStandard("pas", 1)    // PARAMETER
    mechStd.set("g_pas", 8.968609865470852e-05)    // (S/cm2)
    mechStd.set("e_pas", -85.0)    // (mV)
