begintemplate ReducedMechComp

    public initHomogenBiophysics
    public name, list_ref, isMechInserted, mechStds
    
    external math
    external eachSecInList
    
    strdef name
    objref list_ref
    double isMechInserted[1]
    objref mechStds[1][1]
    
    objref mechType
    numMechs = -1
    
    
    proc init() {
        name = $s1
        list_ref = $o2
        
        mechType = new MechanismType(0) // 0: "Distributed Membrane Mechanisms"
        numMechs = mechType.count
        
        double isMechInserted[numMechs]
        objref mechStds[numMechs][3]    // 0: "PARAMETER", 1: "ASSIGNED", 2: "STATE"
    }
    
    // Keep in sync with MechComp.applyHomogenChangesToDirtyMechs in the main program
    proc initHomogenBiophysics() { local morphologyMechIdx, diamVarTypeIdx, mechIdx, varTypeIdx, diamValue localobj mechStd, nil
        strdef diamVarName
        
        morphologyMechIdx = 0
        diamVarTypeIdx = 0
        diamVarName = "diam"
        
        for mechIdx = 0, numMechs - 1 {
            if (!isMechInserted[mechIdx]) {
                continue
            }
            mechType.select(mechIdx)
            for eachSecInList(list_ref) {
                mechType.make()
                for varTypeIdx = 0, 2 {     // 0: "PARAMETER", 1: "ASSIGNED", 2: "STATE"
                    mechStd = mechStds[mechIdx][varTypeIdx]
                    if (mechStd == nil) {
                        continue
                    }
                    if (mechIdx != morphologyMechIdx || varTypeIdx != diamVarTypeIdx) {
                        // Here we assign NaN values to inhom vars, but they will be overwritten shortly downstream
                        mechStd.out()
                    } else {
                        diamValue = mechStd.get(diamVarName)
                        if (!math.isNaN(diamValue)) {
                            diam = diamValue
                        }
                    }
                }
            }
        }
    }
    
endtemplate ReducedMechComp

// "Soma"
obfunc _getListOfSecRefsForComp1() { local idx1, idx2 localobj list_ref
    list_ref = new List()
    soma list_ref.append(new SectionRef())
    return list_ref
}

// "Dendrites"
obfunc _getListOfSecRefsForComp2() { local idx1, idx2 localobj list_ref
    list_ref = new List()
    dendrite1 list_ref.append(new SectionRef())
    dendrite2 list_ref.append(new SectionRef())
    dendrite3 list_ref.append(new SectionRef())
    dendrite4 list_ref.append(new SectionRef())
    dendrite5 list_ref.append(new SectionRef())
    return list_ref
}

// "Small Glia"
obfunc _getListOfSecRefsForComp3() { local idx1, idx2 localobj list_ref
    list_ref = new List()
    for idx1 = 0, 59 {
        for idx2 = 0, 9 {
            AstrocyteNanoBranch[idx1].SmallGlia[idx2] list_ref.append(new SectionRef())
        }
    }
    return list_ref
}

// "Large Glia"
obfunc _getListOfSecRefsForComp4() { local idx1, idx2 localobj list_ref
    list_ref = new List()
    for idx1 = 0, 59 {
        for idx2 = 0, 9 {
            AstrocyteNanoBranch[idx1].LargeGlia[idx2] list_ref.append(new SectionRef())
        }
    }
    return list_ref
}

mmAllComps = new List()

_comp = new ReducedMechComp("Soma", _getListOfSecRefsForComp1())
{ mmAllComps.append(_comp) }

_comp = new ReducedMechComp("Dendrites", _getListOfSecRefsForComp2())
{ mmAllComps.append(_comp) }

_comp = new ReducedMechComp("Small Glia", _getListOfSecRefsForComp3())
{ mmAllComps.append(_comp) }

_comp = new ReducedMechComp("Large Glia", _getListOfSecRefsForComp4())
{ mmAllComps.append(_comp) }

