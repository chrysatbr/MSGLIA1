begintemplate ReducedTapSet

    public applyInhomogeneityIter, createNewPpAttachedToSection
    
    objref this
    
    
    // Keep in sync with TapSet.applyInhomogeneityIter
    iterator applyInhomogeneityIter() { local tapIdx localobj xmAllTaps, distFuncHelper, prevSec_ref, tap, nil
        xmAllTaps = $o2
        distFuncHelper = $o3
        
        distFuncHelper.onJustBeforeFirstSection()
        {
            prevSec_ref = nil
            for tapIdx = 0, xmAllTaps.count() - 1 {
                tap = xmAllTaps.o(tapIdx)
                if (tap.sec_ref != prevSec_ref) {
                    distFuncHelper.onJustBeforeNewSection()
                }
                $o1 = tap
                iterator_statement
                prevSec_ref = tap.sec_ref
            }
        }
        distFuncHelper.onJustAfterLastSection()
    }
    
    _x = -1
    objref _tempPp
    
    // Keep in sync with MechTypeHelper.createNewPpAttachedToSection
    obfunc createNewPpAttachedToSection() { localobj sec_ref, pp, nil
        strdef mechName, hocCommand
        
        mechName = $s1
        sec_ref = $o2
        _x = $3
        
        sprint(hocCommand, "_tempPp = new %s(_x)", mechName)
        sec_ref.sec {
            execute(hocCommand, this)
        }
        
        pp = _tempPp
        _tempPp = nil
        
        return pp
    }
    
endtemplate ReducedTapSet

objref tapSet
tapSet = new ReducedTapSet()

begintemplate ReducedPPComp

    public name, enumDmPpFk, enumPpRole, mechIdx, mechStds
    
    external mth
    external stringEmpty
    
    strdef name
    enumDmPpFk = -1
    enumPpRole = -1
    mechIdx = -1
    objref mechStds[1][1]   // All nil-s except some col(s) of mechIdx row
    
    
    proc init() { local isGapJuncOrSyn, numMechs localobj mechType
        strdef mechName
        
        isGapJuncOrSyn = $1     // Just a placeholder
        name = $s2
        enumPpRole = $3
        mechName = $s4
        
        if (!stringEmpty(mechName)) {
            mechIdx = mth.getMechIdx(1, mechName)
        } else {
            mechIdx = -1
        }
        
        enumDmPpFk = 1
        
        mechType = new MechanismType(1) // 1: "Point Processes"
        numMechs = mechType.count
        objref mechStds[numMechs][3]    // 0: "PARAMETER", 1: "ASSIGNED", 2: "STATE"
    }
    
endtemplate ReducedPPComp

begintemplate ReducedFakeComp

    public enumDmPpFk, enumPpRole, mechStds
    
    enumDmPpFk = -1
    enumPpRole = -1
    objref mechStds[1][1]
    
    proc init() { local fixedMechIdx, numMechs
        enumPpRole = $1
        fixedMechIdx = $2
        enumDmPpFk = 2
        numMechs = fixedMechIdx + 1
        objref mechStds[numMechs][1]
    }
    
endtemplate ReducedFakeComp

objref _allComps

